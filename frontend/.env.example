# ============================================================
# SPYCE FRONTEND - Environment Variables
# ============================================================
# Copy this as ".env" (remove .example)
# On Vercel: add these in Project → Settings → Environment Variables
# ============================================================

# Your backend API URL
# During development: http://localhost:5000
# After Render deploy: https://spyce-api.onrender.com
VITE_API_URL=https://YOUR_RENDER_BACKEND_URL.onrender.com

# Pi Network App ID from Developer Portal
# Found in: develop.pi → Your App → App Overview
VITE_PI_APP_ID=YOUR_PI_APP_ID_HERE

# Environment: "development" or "production"
VITE_ENV=development
# Set to "production" on Vercel
